{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "build:wc": "vite build && node scripts/copy-wc-test.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "preview:wc": "vite preview --host 0.0.0.0 --port 4173",
